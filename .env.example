# =====================================================
# BakeryQ Frontend — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit your real .env to GitHub!
# =====================================================

# Backend API base URL
# Local development:
VITE_API_BASE_URL=http://localhost:8080/api
# Production (uncomment and set after deploying backend to Render):
# VITE_API_BASE_URL=https://bakeryq-backend.onrender.com/api

# Razorpay PUBLIC key (safe to expose in frontend)
# Get from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# App display name
VITE_APP_NAME=BakeryQ
VITE_SHOP_NAME=BakeryQ - Fresh Baked Daily
